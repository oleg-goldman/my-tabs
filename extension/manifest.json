{
  "manifest_version": 3,
  "name": "My Tabs",
  "version": "1.0.0",
  "description": "New tab: my links with instant search + browser history search",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["history", "favicon"],
  "host_permissions": ["https://oleg-goldman.github.io/*"]
}
